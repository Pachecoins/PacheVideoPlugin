{
  "manifestVersion": 5,
  "id": "com.pachevideo.premiere",
  "name": "PacheVideo Tools",
  "version": "0.3.1",
  "main": "index.html",
  "host": {
    "app": "premierepro",
    "minVersion": "25.6.0"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "pachevideoPanel",
      "label": {
        "default": "PacheVideo Tools"
      },
      "minimumSize": {
        "width": 280,
        "height": 420
      },
      "preferredDockedSize": {
        "width": 340,
        "height": 620
      },
      "preferredFloatingSize": {
        "width": 380,
        "height": 680
      }
    }
  ],
  "icons": [
    {
      "width": 24,
      "height": 24,
      "path": "icons/icon24.png",
      "scale": [1, 2]
    }
  ],
  "requiredPermissions": {
    "network": {
      "domains": "all"
    },
    "clipboard": "read",
    "localFileSystem": "request",
    "launchProcess": {
      "extensions": ["", ".mp4", ".mp3", ".m4a", ".mov", ".webm"],
      "schemes": ["https"]
    }
  }
}
