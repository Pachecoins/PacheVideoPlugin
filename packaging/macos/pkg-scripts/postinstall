#!/bin/bash
set -u

LOG="/var/log/PacheVideoInstaller.log"
CCX="/Library/Application Support/PacheVideo/PacheVideo-Premiere.ccx"
UPIA="/Library/Application Support/Adobe/Adobe Desktop Common/RemoteComponents/UPI/UnifiedPluginInstallerAgent/UnifiedPluginInstallerAgent.app/Contents/MacOS/UnifiedPluginInstallerAgent"
PLIST="/Library/LaunchAgents/com.pachevideo.helper.plist"

exec >>"$LOG" 2>&1
echo "$(date -u '+%Y-%m-%dT%H:%M:%SZ') Installing PacheVideo Premiere"

if [[ ! -x "$UPIA" ]]; then
  echo "Adobe UPIA no está instalado. Instalá o actualizá Creative Cloud Desktop."
  exit 1
fi

"$UPIA" --install "$CCX"
UPIA_STATUS=$?
if [[ $UPIA_STATUS -ne 0 ]]; then
  echo "UPIA no pudo instalar $CCX (código $UPIA_STATUS)."
  exit $UPIA_STATUS
fi

CONSOLE_USER="$(stat -f '%Su' /dev/console 2>/dev/null || true)"
if [[ -n "$CONSOLE_USER" && "$CONSOLE_USER" != "root" ]]; then
  USER_ID="$(id -u "$CONSOLE_USER")"
  chown root:wheel "$PLIST"
  chmod 644 "$PLIST"
  launchctl bootout "gui/${USER_ID}" "$PLIST" >/dev/null 2>&1 || true
  launchctl bootstrap "gui/${USER_ID}" "$PLIST"
  launchctl kickstart -k "gui/${USER_ID}/com.pachevideo.helper" || true
fi

echo "Instalación completada."
exit 0
